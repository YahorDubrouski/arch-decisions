# Copy to .env in this directory (gitignored). Used by root docker-compose and backend/docker-compose.

# --- Runtime ---
NODE_ENV=development
PORT=3000
DATABASE_PATH=./data/decisions.db

# --- Logging ---
LOG_LEVEL=info

# --- OpenAI (decision provider) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
